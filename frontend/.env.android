# Android Configuration
# This file is used when building the Android app

# API Configuration for Android Emulator
# The emulator uses 10.0.2.2 to access the host machine
REACT_APP_API_BASE_URL=http://10.0.2.2:8080/api

# For physical devices, set this to your PC's IP (192.168.8.102)
# REACT_APP_DEVICE_IP=http://192.168.8.102:8080/api

# Build identification
REACT_APP_BUILD_TARGET=android
